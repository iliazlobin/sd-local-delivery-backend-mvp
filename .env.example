# Local Delivery MVP — Environment Variables
# Copy to .env and customize for local development.

# ── Application ───────────────────────────────────────────────────────────
# Host port for the app service (internal container port is always 8000)
APP_PORT=8010

# ── PostgreSQL connection (asyncpg) ───────────────────────────────────────
# For local dev (no Docker): localhost. For Docker Compose: db (service name).
DATABASE_URL=postgresql+asyncpg://local_delivery:local_delivery@localhost:5432/local_delivery

# ── Redis connection ──────────────────────────────────────────────────────
# For local dev (no Docker): localhost. For Docker Compose: redis (service name).
REDIS_URL=redis://localhost:6379/0

# ── HTTP server ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
