# verify/manifest.env — consumed by ~/Hermes/bin/e2e-verify and CI
# Required keys: MODE, PORT, BOARD, UP, DOWN, READY, LOGS, TEST_DEPS, ACCEPTANCE
#
# The e2e-verify init command fills in UP/DOWN/READY/LOGS for this project.
# The architect sets TEST_DEPS and ACCEPTANCE (the fixed acceptance contract).

MODE=compose
PORT=8010
BOARD=projects
UP='docker compose up -d --build'
DOWN='docker compose down -v'
READY='curl -sf http://localhost:${PORT}/healthz'
LOGS='docker compose logs app --tail=50'
TEST_DEPS='httpx pytest'
ACCEPTANCE='API_BASE_URL="http://localhost:${PORT}" ${PY:-python} -m pytest verify/acceptance/ -q'
